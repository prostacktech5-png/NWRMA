# Copy to env/nwrma.env (or run npm run sync:env — it bootstraps from server/web env once).
#
# --- Field Android (any network) ---
# NWRMA_API_URL — public HTTPS API baked into the APK (Render, VPS, or dev:field tunnel).
# Leave empty for office-only (same Wi‑Fi as PC via NWRMA_API_URL_LAN).
NWRMA_API_URL=https://nwrma-api.onrender.com
# Optional LAN fallback when on the same Wi‑Fi as your laptop API.
NWRMA_API_URL_LAN=http://192.168.1.21:4000
# auto = public URL first when NWRMA_API_URL is set; lan = office Wi‑Fi only
FIELD_API_PRIORITY=auto

# --- Render web (staff ERP + online forms) ---
PUBLIC_APP_URL=https://nwrma-web.onrender.com
FRONTEND_ORIGINS=https://nwrma-web.onrender.com,http://localhost:3000,http://127.0.0.1:3000

# --- Shared API (laptop dev; on Render set to https://nwrma-api.onrender.com on web service) ---
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
NWRMA_SERVER_URL=http://localhost:4000
NEXT_PUBLIC_NWRMA_SERVER_URL=http://localhost:4000

JWT_SECRET=change-me-long-random-min-16-chars
DATABASE_URL=postgresql://user:pass@host:5432/postgres?sslmode=require

# Optional: first-time seed (dashboard + field officer)
SEED_WEB_ADMIN_EMAIL=admin@nwrma.gov.sl
SEED_WEB_ADMIN_PASSWORD=admin123
SEED_MOBILE_OFFICER_PHONE=+232770000001
SEED_MOBILE_OFFICER_PASSWORD=demo123

# Invitation email (web)
INVITE_SECRET=long-random-string-min-16-chars
INVITE_EXPIRY_DAYS=7
APP_PUBLIC_NAME=National Water Resources Management Agency
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional field ingest proxy key (web)
# HYDRO_API_KEY=
