# Deployment context — keep API/web Docker builds small (see Dockerfile.api / Dockerfile.web)

# Git and IDE
.git
.gitignore
.cursor
.vscode

# Dependencies and build outputs (rebuilt in image)
node_modules
**/node_modules
.next
**/.next
dist
server/dist
shared/dist
*.tsbuildinfo

# Mobile app source (workspace stub created in Dockerfile — do not send 100s of MB to the builder)
mobile/**
android app/**

# Large dev-only media (web marketing still works without raw video in image)
tst/**/*.mp4
tst/**/*.mov
tst/**/*.webm
tst/**/*.avi

# Docs and local deploy configs (not needed in image)
docs/**
*.md
render.yaml
railway.toml
railway.*.toml
nixpacks.toml
nixpacks.api.toml

# Runtime uploads — mount Railway volume at /app/web/data for web service
web/data
data

# APKs and local secrets
*.apk
env/nwrma.env
server/.env
server/.env.local
web/.env.local
mobile/.env

# Render / Railway / misc deploy noise
render.yaml
.cursor/plans

# Large dev-only trees (optional: tst kept for web marketing prepare:public)
# Uncomment to shrink web build further if marketing video not needed:
# tst/**/*.mp4
# tst/**/*.mov
