# --- Prisma + Next.js web must share this URI ---
# Use the same DATABASE_URL in web/.env.local so invitations (set-password), ERP routes, and Express login hit one Supabase DB.
# Prefer Session pooler (5432 + user postgres.<project_ref>) on Windows/DNS issues; direct db.<ref>:5432 may be unreachable.
# Copy host/region from Supabase → Connect → Session pooler. URL-encode @ # : in the password.
DATABASE_URL="postgresql://postgres.zsjkyenjjgihkqsgthfz:REPLACE_WITH_DATABASE_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require"

SUPABASE_URL="https://zsjkyenjjgihkqsgthfz.supabase.co"
SUPABASE_REST_URL="https://zsjkyenjjgihkqsgthfz.supabase.co/rest/v1/"

SUPABASE_ANON_KEY=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SECRET_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Express API JWT signing secret (pick a long random string for production).
JWT_SECRET=""

PORT=4000
# Listen on all interfaces so phones/emulators reach the API; pair with mobile EXPO_PUBLIC_* LAN URL.
HOST=0.0.0.0
FRONTEND_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001"
NODE_ENV=development

# Optional: prisma:seed updates password hashes + roles for these users each run.
# SEED_WEB_ADMIN_EMAIL=admin@example.com
# SEED_WEB_ADMIN_PASSWORD=change-me
# SEED_MOBILE_OFFICER_PHONE=+232000000001
# SEED_MOBILE_OFFICER_PASSWORD=demo123
