{
  "name": "@nwrma/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run build -w @nwrma/shared",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "node ./scripts/run-prisma.mjs generate",
    "prisma:migrate": "node ./scripts/run-prisma.mjs migrate deploy",
    "prisma:migrate:dev": "node ./scripts/run-prisma.mjs migrate dev",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nwrma/shared": "*",
    "@prisma/client": "^6.8.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.30",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "5.7.3"
  }
}
