# Copy to .env — values are baked in at `expo prebuild` / `expo run:android`; rebuild after changing URL.

# Android emulator → Express on your PC (10.0.2.2 = host loopback from the emulator).
EXPO_PUBLIC_NWRMA_SERVER_URL=http://10.0.2.2:4000

# Physical phone — same Wi‑Fi as PC: PC's LAN IPv4 + server HOST=0.0.0.0 (see server/.env.example). Rebuild APK after changing IP.
# EXPO_PUBLIC_NWRMA_SERVER_URL=http://192.168.1.50:4000

# HTTPS production API — prefer this for installs off-LAN / Play Store builds (omit cleartext need).
# EXPO_PUBLIC_NWRMA_SERVER_URL=https://api.example.gov.sl
