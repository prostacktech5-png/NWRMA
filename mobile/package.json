{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "prebuild:android": "expo prebuild --platform android",
    "build:apk": "cross-env EXPO_NO_METRO_WORKSPACE_ROOT=1 npm run sync:env --prefix .. && node ../scripts/with-jdk17.mjs -- .\\android\\gradlew.bat assembleRelease -PreactNativeArchitectures=arm64-v8a",
    "build:apk:studio": "npm run sync:env --prefix .. && npx expo run:android --variant release",
    "android:release": "expo run:android --variant release",
    "android": "expo run:android",
    "android:8082": "expo start --android --port 8082",
    "android:5554": "cross-env ANDROID_SERIAL=emulator-5554 expo start --android",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@nwrma/shared": "*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-location": "~19.0.8",
    "expo-sqlite": "~15.1.4",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-get-random-values": "~1.11.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "cross-env": "^10.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
