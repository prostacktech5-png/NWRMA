# NWRMA Next.js web — Railway service: nwrma-web
# Sevalla/Railway: Dockerfile path = Dockerfile.web OR Dockerfile (root includes this file)
# Mount volume at /app/web/data for uploads.

FROM node:20-bookworm-slim AS build

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends openssl ca-certificates \
  && rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json .npmrc ./
COPY shared/package.json ./shared/
COPY web/package.json ./web/
COPY server/package.json ./server/
RUN mkdir -p mobile && printf '%s\n' '{"name":"mobile","version":"1.0.0","private":true}' > mobile/package.json

COPY shared ./shared
COPY web ./web
COPY tst ./tst
COPY scripts ./scripts

RUN npm ci --include=optional --workspace=@nwrma/shared --workspace=my-project

RUN npm install @tailwindcss/oxide-linux-x64-gnu@4.3.0 -w my-project --no-audit --no-fund

RUN npm run build -w @nwrma/shared \
  && npm run prepare:public -w my-project \
  && npm run build -w my-project

FROM node:20-bookworm-slim AS run

WORKDIR /app

ENV NODE_ENV=production

RUN apt-get update && apt-get install -y --no-install-recommends openssl ca-certificates \
  && rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json .npmrc ./
COPY shared/package.json ./shared/
COPY web/package.json ./web/
COPY server/package.json ./server/
RUN mkdir -p mobile && printf '%s\n' '{"name":"mobile","version":"1.0.0","private":true}' > mobile/package.json

COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/shared ./shared
COPY --from=build /app/web ./web

RUN mkdir -p /app/web/data

WORKDIR /app/web

EXPOSE 8080

CMD ["npm", "run", "start"]
