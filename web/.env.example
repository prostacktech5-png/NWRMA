# Supabase Postgres URI — must match `server/.env` `DATABASE_URL` (one database for Express + Next ERP routes).
# Dashboard → Project Settings → Database → Connection string → URI (Session pooler on 5432 recommended).
DATABASE_URL=

# NWRMA Express API (optional: JWT login + upstream `/auth/login` + field reports merge).
NWRMA_SERVER_URL=http://localhost:4000

# Optional public copy for client-only code
NEXT_PUBLIC_NWRMA_SERVER_URL=http://localhost:4000

# Field apps POST readings to /api/hydrological/readings with X-Hydro-Api-Key when set.
# Same key must be set in android app/.env.local (HYDRO_API_KEY) for the sync proxy.
# HYDRO_API_KEY=

# Optional: guarded demo dataset load into Postgres (not for production UAT).
# POST /api/admin/seed-database with header x-seed-secret: <value>
# SEED_SECRET=long-random-string

# --- Invitation emails (Next.js API → nodemailer)
# PUBLIC_APP_URL=http://localhost:3000
# INVITE_SECRET=long-random-string-min-16-chars
# INVITE_EXPIRY_DAYS=7
# APP_PUBLIC_NAME=NWRMA ERP
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-account@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="NWRMA ERP <your-account@gmail.com>"
# SMTP_NOTIFY_TO=admin@example.com
#
# Verify: npm run smtp-test
